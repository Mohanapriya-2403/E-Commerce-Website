PORT=5000
NODE_ENV=development

# IMPORTANT: Make sure there are NO spaces around the '=' sign
# Replace <username> and <password> with your MongoDB Atlas details
MONGO_URI=mongodb:////<username>:<password>@cluster0.mongodb.net/myShop?retryWrites=true&w=majority

# You can put any random string here for security
JWT_SECRET=anything_you_want_12345